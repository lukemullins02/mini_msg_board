<html>
  <head>
    <link rel="stylesheet" href="/styles.css" >
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&display=swap" rel="stylesheet">
  </head>
  <body class="roboto-text">
   <%- include('navbar') %>
    <div class="card-container">
    <% for (let i = 0; i < messages.length; i++) { %>
       <div class="card">
        <p class="user"><%= messages[i].user %> <a href="/messages/<%= i %>"><svg class="expand-icon" width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
              <path d="M14 10L21 3M21 3H16.5M21 3V7.5M10 14L3 21M3 21H7.5M3 21L3 16.5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
            </svg></a></p>
        <p><%= messages[i].text %></p>
        <p><i><%= Intl.DateTimeFormat('en-US', {
          timeStyle: 'short',
          dateStyle: 'short',
        }).format(messages[i].added) %> </i></p>
    </div>
    <% } %>
</div>
  </body>
</html>
