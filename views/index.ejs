<html>
  <head>
    <%= title %>
  </head>
  <body>
    <a href="/new" >New Message</a>
    <% for (let i = 0; i < messages.length; i++) { %>
        <p><%= messages[i].user %></p>
        <p><%= messages[i].text %></p>
        <p><%= messages[i].added %></p>
        <a href="/messages/<%= i %>">Open </a>

    <% } %>
  </body>
</html>
